{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Lifebot",
  "version": "0.1.0",
  "identifier": "local.lifebot.desktop",
  "build": {
    "beforeDevCommand": "npm run frontend:build",
    "beforeBuildCommand": "npm run frontend:build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Lifebot",
        "width": 1440,
        "height": 980,
        "resizable": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
        "icons/icon.png",
        "icons/32x32.png",
        "icons/128x128.png",
        "icons/128x128@2x.png",
        "icons/icon.icns",
        "icons/icon.ico"
      ]
  }
}
